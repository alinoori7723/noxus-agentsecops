# Version control / metadata
.git/
.gitignore

# Virtual environments (incl. transient validation venvs like .venv-final-polish)
.venv/
.venv*/
venv/
*venv*/

# Python caches / build artifacts
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Local run outputs / audit exports / logs
outputs/
reports/
tmp/
*.log

# Tests are not needed in the runtime image
tests/

# Frontend deps / build artifacts (rebuilt inside the Docker build stage)
node_modules/
**/node_modules/
apps/web/node_modules/
dist/
apps/web/dist/

# Claude harness / session settings
.claude/

# Screenshots / scratch captures
screenshots/
**/screenshots/

# Local environment files
.env
.env.*

# OS / editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
